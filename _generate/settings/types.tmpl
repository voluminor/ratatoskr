{{- define "structFields" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.IsTrigger }}
            {{ $leaf.Name }} {{ $leaf.Type }} `json:"-" yaml:"-"`
        {{- else if $leaf.Branch }}
            {{- if $leaf.Usage }}
                // {{ $leaf.Usage }}
            {{- end }}
            {{ $leaf.Name }} {{ $leaf.Type }} `json:"{{ $leaf.Key }}" yaml:"{{ $leaf.Key }}"`
        {{- else }}
            {{ $leaf.Name }} {{ $leaf.Type }} `json:"{{ $leaf.Key }}" yaml:"{{ $leaf.Key }}"`
        {{- end }}
    {{- end }}
{{- end -}}

{{- define "nestedStructs" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.Branch }}

            {{- if $leaf.Usage }}
                // {{ $leaf.Usage }}
            {{- end }}
            type {{ $leaf.Type }} struct {
            {{- template "structFields" $leaf.Branch }}
            }

            func (o *{{ $leaf.Type }}) Self() any { return o }
            {{- template "nestedStructs" $leaf.Branch }}
        {{- end }}
    {{- end }}
{{- end -}}

{{- define "genInterfaces" -}}
    {{- range $key, $leaf := . }}
        {{- if and $leaf.Branch $leaf.GenInterface }}

            {{- if $leaf.Usage }}
                // {{ $leaf.Usage }}
            {{- end }}
            type {{ $leaf.InterfaceType }} interface {
            {{- range $subKey, $subLeaf := $leaf.Branch }}
                {{- if $subLeaf.Branch }}
                    {{- if $subLeaf.GenInterface }}
                        Get{{ $subLeaf.Name }}() {{ $subLeaf.InterfaceType }}
                    {{- else }}
                        Get{{ $subLeaf.Name }}() *{{ $subLeaf.Type }}
                    {{- end }}
                {{- else }}
                    Get{{ $subLeaf.Name }}() {{ $subLeaf.Type }}
                {{- end }}
            {{- end }}
            Self() any
            }
            {{- template "genInterfaces" $leaf.Branch }}
        {{- end }}
    {{- end }}
{{- end -}}

{{- define "structGetters" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.Branch }}
            {{- range $subKey, $subLeaf := $leaf.Branch }}
                {{- if $subLeaf.Branch }}
                    {{- if $subLeaf.GenInterface }}
                        func (o *{{ $leaf.Type }}) Get{{ $subLeaf.Name }}() {{ $subLeaf.InterfaceType }} { return &o.{{ $subLeaf.Name }} }
                    {{- else }}
                        func (o *{{ $leaf.Type }}) Get{{ $subLeaf.Name }}() *{{ $subLeaf.Type }} { return &o.{{ $subLeaf.Name }} }
                    {{- end }}
                {{- else }}
                    func (o *{{ $leaf.Type }}) Get{{ $subLeaf.Name }}() {{ $subLeaf.Type }} { return o.{{ $subLeaf.Name }} }
                {{- end }}
            {{- end }}
            {{- template "structGetters" $leaf.Branch }}
        {{- end }}
    {{- end }}
{{- end -}}
// Code generated using '_generate/settings'; DO NOT EDIT.
// Generation time: {{.GenerationTime}}
{{- if gt (len .Path) 3 }}
    // mod-path: {{ .Path }}
{{- end }}

package settings

{{- if gt (len .TypesImports) 0 }}
    {{- if eq (len .TypesImports) 1 }}
        import "{{ index .TypesImports 0 }}"
    {{- else }}
        import (
        {{- range .TypesImports }}
            "{{ . }}"
        {{- end }}
        )
    {{- end }}
{{ end }}

// // // // // // // // // //

type Obj struct {
{{- template "structFields" .Tree }}
}
{{ template "nestedStructs" .Tree }}

// //

func (o *Obj) Self() any { return o }

// //
{{ range $key, $leaf := .Tree }}
    {{- if $leaf.Branch }}
        {{- if $leaf.GenInterface }}
            func (o *Obj) Get{{ $leaf.Name }}() {{ $leaf.InterfaceType }} { return &o.{{ $leaf.Name }} }
        {{- else }}
            func (o *Obj) Get{{ $leaf.Name }}() *{{ $leaf.Type }} { return &o.{{ $leaf.Name }} }
        {{- end }}
    {{- else }}
        func (o *Obj) Get{{ $leaf.Name }}() {{ $leaf.Type }} { return o.{{ $leaf.Name }} }
    {{- end }}
{{- end }}
{{ template "structGetters" .Tree }}

// //
{{ template "genInterfaces" .Tree }}
