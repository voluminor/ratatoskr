{{- define "goType" -}}
    {{- if eq . "duration" }}time.Duration{{- else if eq . "float" }}float32{{- else }}{{ . }}{{- end -}}
{{- end -}}

{{- define "structFields" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.Branch }}
            {{ $leaf.Name }} {{ $leaf.Type }} `koanf:"{{ $key }}" json:"{{ $key }}"`
        {{- else }}
            {{ $leaf.Name }} {{ template "goType" $leaf.Type }} `koanf:"{{ $key }}" json:"{{ $key }}"`
        {{- end }}
    {{- end }}
{{- end -}}

{{- define "nestedStructs" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.Branch }}

            type {{ $leaf.Type }} struct {
            {{- template "structFields" $leaf.Branch }}
            }
            {{- template "nestedStructs" $leaf.Branch }}
        {{- end }}
    {{- end }}
{{- end -}}

{{- define "structGetters" -}}
    {{- range $key, $leaf := . }}
        {{- if $leaf.Branch }}
            {{- range $subKey, $subLeaf := $leaf.Branch }}
                {{- if $subLeaf.Branch }}
                    func (o *{{ $leaf.Type }}) Get{{ $subLeaf.Name }}() *{{ $subLeaf.Type }} { return &o.{{ $subLeaf.Name }} }
                {{- else }}
                    func (o *{{ $leaf.Type }}) Get{{ $subLeaf.Name }}() {{ template "goType" $subLeaf.Type }} { return o.{{ $subLeaf.Name }} }
                {{- end }}
            {{- end }}
            {{- template "structGetters" $leaf.Branch }}
        {{- end }}
    {{- end }}
{{- end -}}
// Code generated using '_generate/settings'; DO NOT EDIT.
// Generation time: {{.GenerationTime}}
{{- if gt (len .Path) 3 }}
    // mod-path: {{ .Path }}
{{- end }}

package settings

import (
{{- if .HasDuration }}
    "time"
{{ end }}
"github.com/spf13/pflag"
)

// // // // // // // // // //

type Obj struct {
{{- template "structFields" .Tree }}
}
{{ template "nestedStructs" .Tree }}

// //

var values = map[string]any{
{{- range .Flags }}
    {{- if .Value }}
        {{- if eq .Type "string" }}
            "{{ .Name }}": "{{ .Value }}",
        {{- else }}
            "{{ .Name }}": {{ .Value }},
        {{- end }}
    {{- end }}
{{- end }}
}

//

func (*Obj) Values() map[string]any {
return values
}

func (*Obj) DefineFlags(fs *pflag.FlagSet) {
{{- range .Flags }}
    {{- if eq .Type "string" }}
        fs.String("{{ .Name }}", "", "{{ .Usage }}")
    {{- else if eq .Type "int" }}
        fs.Int("{{ .Name }}", 0, "{{ .Usage }}")
    {{- else if eq .Type "bool" }}
        fs.Bool("{{ .Name }}", false, "{{ .Usage }}")
    {{- else if eq .Type "float" }}
        fs.Float32("{{ .Name }}", 0, "{{ .Usage }}")
    {{- else if eq .Type "duration" }}
        fs.Duration("{{ .Name }}", 0, "{{ .Usage }}")
    {{- end }}
{{- end }}
}

// //
{{ range $key, $leaf := .Tree }}
    {{- if $leaf.Branch }}
        func (o *Obj) Get{{ $leaf.Name }}() *{{ $leaf.Type }} { return &o.{{ $leaf.Name }} }
    {{- else }}
        func (o *Obj) Get{{ $leaf.Name }}() {{ template "goType" $leaf.Type }} { return o.{{ $leaf.Name }} }
    {{- end }}
{{- end }}
{{ template "structGetters" .Tree }}
